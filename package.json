{
  "name": "greenware",
  "version": "0.1.0",
  "description": "Website form lead routing for Clay-powered backend",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "bun --filter '@greenware/server' dev",
    "start": "bun --filter '@greenware/server' start",
