GREENWARE_ENV=development

# Optional stable keys. If omitted, Greenware uses ephemeral runtime keys.
# GREENWARE_SIGNING_KEY=replace-with-openssl-rand-hex-32
# GREENWARE_READ_KEY=replace-with-openssl-rand-hex-32

# Optional protected setup endpoints.
# GREENWARE_SETUP_TOKEN=replace-with-openssl-rand-hex-32

# Optional deploy-time overrides. Railway provides RAILWAY_PUBLIC_DOMAIN itself.
# GREENWARE_PUBLIC_URL=https://greenware.yourcompany.com
# GREENWARE_ALLOWED_ORIGINS=https://your-site.com,https://your-ngrok.ngrok-free.app

# One or more Clay/enrichment destinations. The key usually matches form_id.
# If no form_id matches, Greenware uses "default".
# GREENWARE_DESTINATIONS={"default":{"webhook_url":"INSERT_WEBHOOK_URL_HERE","headers":{"x-clay-webhook-auth":"INSERT_AUTH_TOKEN_HERE"}},"enterprise-demo":{"webhook_url":"INSERT_ENTERPRISE_WEBHOOK_URL_HERE","headers":{"x-clay-webhook-auth":"INSERT_ENTERPRISE_AUTH_TOKEN_HERE"}}}

# Optional rotation grace key.
# GREENWARE_SIGNING_KEY_PREVIOUS=replace-with-previous-key
